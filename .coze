[project]
requires = ["nodejs-24", "python-3.11"]

[dev]
build = ["bash", "-c", "pip install -r requirements.txt && cd frontend && pnpm install"]
run = ["bash", "-c", "uvicorn backend.main:app --host 0.0.0.0 --port 5000"]

[deploy]
build = ["bash", "-c", "pip install -r requirements.txt && cd frontend && pnpm install && pnpm build"]
run = ["bash", "-c", "uvicorn backend.main:app --host 0.0.0.0 --port 5000"]
